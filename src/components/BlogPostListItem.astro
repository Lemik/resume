---
import type { CollectionEntry } from 'astro:content';
import { withBase, resolvePublicOrAbsolute } from '../utils/url';

interface Props {
	post: CollectionEntry<'blog'>;
	showTags?: boolean;
}

const { post, showTags = false } = Astro.props;
const imgSrc = post.data.image ? resolvePublicOrAbsolute(post.data.image) : null;
const postHref = withBase(`blog/${post.id}`);
---

<li class="post-list__item">
	<div class="post-list__body">
		<a class="title" href={postHref}>{post.data.title}</a>
		<time datetime={post.data.pubDate.toISOString()}>
			{
				post.data.pubDate.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				})
			}
		</time>
		<p class="excerpt">{post.data.description}</p>
		{
			showTags && post.data.tags?.length ? (
				<div class="chips post-list__tags">
					{post.data.tags.map((tag) => (
						<span class="chip">{tag}</span>
					))}
				</div>
			) : null
		}
	</div>
	{
		imgSrc ? (
			<div class="post-list__thumb-panel">
				<img
					class="post-list__thumb"
					src={imgSrc}
					alt=""
					width="224"
					height="140"
					loading="lazy"
					decoding="async"
				/>
			</div>
		) : null
	}
</li>
