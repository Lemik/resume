---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostListItem from '../../components/BlogPostListItem.astro';
import { getCollection } from 'astro:content';
import { publishedBlogPosts } from '../../utils/blog';

const posts = publishedBlogPosts(await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
	title="Blog — Leonid Dushin"
	description="Articles and notes on test automation, performance, and delivery."
	navKey="blog"
>
	<h1 class="page-title">Blog</h1>

	{
		posts.length ? (
			<ul class="post-list">
				{posts.map((post) => (
					<BlogPostListItem post={post} showTags />
				))}
			</ul>
		) : (
			<p class="subtitle" style="margin-top: 0;">No posts yet. Add a <code>.md</code> file under <code>src/content/blog/</code> to publish here.</p>
		)
	}
</BaseLayout>
