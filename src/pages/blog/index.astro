---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/url';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
	title="Blog — Leonid Dushin"
	description="Articles and notes on test automation, performance, and delivery."
	navKey="blog"
>
	<h1 class="page-title">Blog</h1>
	<p class="subtitle">
		Markdown posts live in <code>src/content/blog/</code>. Frontmatter is defined in <code>src/content.config.ts</code>.
	</p>
	{
		posts.length ? (
			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a class="title" href={withBase(`blog/${post.id}`)}>
							{post.data.title}
						</a>
						<time datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</time>
						<p class="excerpt">{post.data.description}</p>
						{post.data.tags?.length ? (
							<div class="chips" style="margin-top: 0.5rem;">
								{post.data.tags.map((tag) => (
									<span class="chip">{tag}</span>
								))}
							</div>
						) : null}
					</li>
				))}
			</ul>
		) : (
			<p class="subtitle" style="margin-top: 0;">No posts yet. Add a <code>.md</code> file under <code>src/content/blog/</code> to publish here.</p>
		)
	}
</BaseLayout>
