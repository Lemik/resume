---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { resolvePublicOrAbsolute } from '../../utils/url';
import { publishedBlogPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = publishedBlogPosts(await getCollection('blog'));
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} — Blog`;
const coverSrc = post.data.image ? resolvePublicOrAbsolute(post.data.image) : null;
const coverAlt = post.data.imageAlt ?? post.data.title;
---

<BaseLayout title={title} description={post.data.description} navKey="blog">
	<article class="prose">
		<h1>{post.data.title}</h1>
		<p class="meta">
			<time datetime={post.data.pubDate.toISOString()}>
				{post.data.pubDate.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'long',
					day: 'numeric',
				})}
			</time>
			{
				post.data.updatedDate ? (
					<>
						{' '}
						· Updated{' '}
						<time datetime={post.data.updatedDate.toISOString()}>
							{post.data.updatedDate.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})}
						</time>
					</>
				) : null
			}
			{
				post.data.tags?.length ? (
					<>
						{' '}
						· {post.data.tags.join(', ')}
					</>
				) : null
			}
		</p>
		{
			coverSrc ? (
				<figure class="prose-cover">
					<img src={coverSrc} alt={coverAlt} loading="eager" decoding="async" />
				</figure>
			) : null
		}
		<Content />
	</article>
</BaseLayout>
